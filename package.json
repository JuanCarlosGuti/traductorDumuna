{
  "name": "corpus-damana-app",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicación local de estudio del damana (dʉmʉna), lengua del pueblo Wiwa",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start": "npm run start:dev -w backend",
    "front": "npm run start -w frontend",
    "importar": "npm run importar -w backend",
    "build": "npm run build -w frontend && npm run build -w backend",
    "start:prod": "npm run start:prod -w backend",
    "test": "npm test -w backend",
    "test:e2e": "npm run test:e2e -w backend",
    "test:front": "npm run test -w frontend"
  }
}
